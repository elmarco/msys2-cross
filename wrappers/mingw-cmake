#!/bin/bash
set -euo pipefail
# CMake wrapper for cross-compilation.
# Uses the generated toolchain file for cross-compiler settings.
# Detects cmake subcommands that don't need cross flags.

case "${1:-}" in
    --build|--install|--open|--preset)
        exec /usr/bin/cmake "$@"
        ;;
esac

exec /usr/bin/cmake \
    -DCMAKE_TOOLCHAIN_FILE=/opt/msys2-cross/generated/toolchain.cmake \
    "$@"
