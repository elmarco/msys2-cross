#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE_NAME="msys2-cross"
CONTAINER_NAME="msys2-cross-dev"
MINGW_PACKAGES_DIR="${SCRIPT_DIR}/MINGW-packages"
PACMAN_CONF="/opt/msys2-cross/config/pacman-mingw.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

msg()  { echo -e "${GREEN}==>${NC} ${BOLD}$1${NC}"; }
warn() { echo -e "${YELLOW}==> WARNING:${NC} ${BOLD}$1${NC}"; }
err()  { echo -e "${RED}==> ERROR:${NC} ${BOLD}$1${NC}" >&2; }

usage() {
    cat <<'EOF'
Usage: msys2-cross <command> [args...]

Commands:
  setup [--force]       First-time setup: download sources, build container,
                        clone MINGW-packages. --force rebuilds the container
  build <pkg> [...]     Build one or more MINGW packages (builds missing deps)
  install <pkg> [...]   Install built packages into the container's sysroot
  deps <pkg>            Show missing dependencies for a package
  shell                 Open an interactive shell in the build container
  run <cmd...>          Run an arbitrary command in the build container
  list                  List installed packages in the sysroot
  rebuild               Rebuild the container image

Package names can omit the "mingw-w64-" prefix:
  msys2-cross build libpng    →  builds mingw-w64-libpng
EOF
    exit "${1:-0}"
}

# Normalize package name: "libpng" → "mingw-w64-libpng"
normalize_pkg() {
    local pkg="$1"
    if [[ "$pkg" != mingw-w64-* ]]; then
        pkg="mingw-w64-${pkg}"
    fi
    echo "$pkg"
}

# Ensure MINGW-packages is cloned
ensure_mingw_packages() {
    if [[ ! -d "${MINGW_PACKAGES_DIR}/.git" ]]; then
        msg "Cloning MINGW-packages (sparse)..."
        git clone --filter=blob:none --sparse \
            https://github.com/msys2/MINGW-packages.git \
            "${MINGW_PACKAGES_DIR}"
    fi
}

# Sparse checkout a package
checkout_pkg() {
    local pkg="$1"
    ensure_mingw_packages
    cd "${MINGW_PACKAGES_DIR}"
    if [[ ! -d "${pkg}" ]]; then
        msg "Checking out ${pkg}..."
        git sparse-checkout add "${pkg}"
    fi
    if [[ ! -d "${pkg}" ]]; then
        err "Package ${pkg} not found in MINGW-packages"
        return 1
    fi
}

# Ensure container image exists
ensure_image() {
    if ! podman image exists "${IMAGE_NAME}"; then
        err "Container image '${IMAGE_NAME}' not found. Run: msys2-cross setup"
        exit 1
    fi
}

# Start or reuse the persistent dev container
ensure_container() {
    ensure_image
    if podman container exists "${CONTAINER_NAME}" 2>/dev/null; then
        if [[ "$(podman inspect -f '{{.State.Running}}' "${CONTAINER_NAME}" 2>/dev/null)" != "true" ]]; then
            podman start "${CONTAINER_NAME}" >/dev/null
        fi
    else
        msg "Creating persistent container ${CONTAINER_NAME}..."
        podman create \
            --name "${CONTAINER_NAME}" \
            --network=none \
            -v "${MINGW_PACKAGES_DIR}:/src" \
            -v "${SCRIPT_DIR}/patches:/opt/msys2-cross/patches:ro" \
            -v "${SCRIPT_DIR}/config/makepkg-mingw:/opt/msys2-cross/config/makepkg-mingw:ro" \
            "${IMAGE_NAME}" sleep infinity >/dev/null
        podman start "${CONTAINER_NAME}" >/dev/null
    fi
}

# Run a command in the persistent container
cexec() {
    ensure_container
    podman exec "${CONTAINER_NAME}" "$@"
}

# Fix ownership of files created by the container
fix_ownership() {
    local dir="$1"
    if [[ -d "$dir" ]]; then
        podman unshare chown -R "$(id -u):$(id -g)" "$dir" 2>/dev/null || true
    fi
}

# Cache of installed packages (populated once per run)
_installed_cache=""

refresh_installed_cache() {
    _installed_cache=$(cexec pacman --config "${PACMAN_CONF}" -Qi 2>/dev/null \
        | grep -E "^(Name|Provides)" \
        | sed -e 's/^Name *: //' -e 's/^Provides *: //' \
        | tr ' ' '\n' \
        | sed 's/[><=].*//' \
        | sort -u)
}

is_installed() {
    local dep="$1"
    if [[ -z "$_installed_cache" ]]; then
        refresh_installed_cache
    fi
    echo "$_installed_cache" | grep -qx "$dep"
}

# Extract MINGW depends/makedepends from a PKGBUILD.
# Sources the PKGBUILD in a subshell with MINGW env vars set.
extract_deps() {
    local pkgbuild="$1"
    local pkgdir
    pkgdir=$(dirname "$pkgbuild")
    local pkgbase
    pkgbase=$(basename "$pkgdir")

    (
        set +eu
        # Work in a temp dir so patches can sed -i PKGBUILD
        local tmpdir
        tmpdir=$(mktemp -d)
        cp "$pkgbuild" "${tmpdir}/PKGBUILD"
        cd "$tmpdir"

        # Apply patch if one exists (patches use sed -i on PKGBUILD)
        local patch="${SCRIPT_DIR}/patches/${pkgbase}.sh"
        if [[ -f "$patch" ]]; then
            source "$patch" 2>/dev/null || true
        fi

        MINGW_PACKAGE_PREFIX="mingw-w64-ucrt-x86_64"
        MINGW_PREFIX="/ucrt64"
        MINGW_CHOST="x86_64-w64-mingw32"
        MSYSTEM="UCRT64"
        CARCH="x86_64"
        check_option() { echo "n"; }
        source PKGBUILD 2>/dev/null || true
        for dep in "${depends[@]}" "${makedepends[@]}"; do
            dep="${dep%%[><=]*}"
            if [[ "$dep" == mingw-w64-ucrt-x86_64-* ]]; then
                echo "$dep"
            fi
        done
        rm -rf "$tmpdir"
    ) 2>/dev/null | sort -u
}

# Map an installed package name back to its MINGW-packages source dir.
# e.g., "mingw-w64-ucrt-x86_64-zlib" → "mingw-w64-zlib"
installed_to_srcpkg() {
    local ipkg="$1"
    # Strip the environment prefix: mingw-w64-ucrt-x86_64-foo → foo
    local name="${ipkg#mingw-w64-ucrt-x86_64-}"
    echo "mingw-w64-${name}"
}

# Find missing deps for a package. Returns list of source package names
# (mingw-w64-foo format) that need to be built.
find_missing_deps() {
    local pkg="$1"

    checkout_pkg "$pkg" >/dev/null 2>&1

    local pkgbuild="${MINGW_PACKAGES_DIR}/${pkg}/PKGBUILD"
    if [[ ! -f "$pkgbuild" ]]; then
        return
    fi

    local deps
    deps=$(extract_deps "$pkgbuild")

    for dep in $deps; do
        if ! is_installed "$dep"; then
            installed_to_srcpkg "$dep"
        fi
    done
}

# Recursively resolve all missing deps (topological order, depth-first).
# Uses global arrays _resolve_visited and _resolve_result.
declare -A _resolve_visited=()
_resolve_result=()

resolve_deps() {
    local pkg="$1"

    if [[ -n "${_resolve_visited[$pkg]+x}" ]]; then
        return
    fi
    _resolve_visited[$pkg]=1

    local missing
    missing=$(find_missing_deps "$pkg")

    for dep_src in $missing; do
        resolve_deps "$dep_src"
    done

    _resolve_result+=("$pkg")
}

# Download sources for a single package
download_sources() {
    local pkg="$1"
    msg "Downloading sources for ${pkg}..."
    podman run --rm \
        -v "${MINGW_PACKAGES_DIR}/${pkg}:/pkg" \
        "${IMAGE_NAME}" \
        bash -c "
            source /opt/msys2-cross/config/mingw-env.sh
            useradd -m builduser 2>/dev/null || true
            chown -R builduser: /pkg
            su builduser -s /bin/bash -c 'cd /pkg && makepkg --verifysource --skipchecksums --skippgpcheck --config /opt/msys2-cross/config/makepkg_mingw.conf --nodeps -f'
        "
    fix_ownership "${MINGW_PACKAGES_DIR}/${pkg}"
}

# Build a single package (no dep resolution)
build_single() {
    local pkg="$1"
    shift
    local makepkg_args=("$@")

    checkout_pkg "$pkg"
    download_sources "$pkg"

    msg "Building ${pkg}..."
    ensure_container
    cexec bash -c "cd /src/${pkg} && makepkg-mingw ${makepkg_args[*]}"
    fix_ownership "${MINGW_PACKAGES_DIR}/${pkg}"
}

# Install a single package
install_single() {
    local pkg="$1"

    local pkgfiles
    pkgfiles=$(find "${MINGW_PACKAGES_DIR}/${pkg}" -name "*.pkg.tar.*" 2>/dev/null | head -20)

    if [[ -z "$pkgfiles" ]]; then
        err "No built packages found for ${pkg}"
        return 1
    fi

    msg "Installing ${pkg}..."
    for f in $pkgfiles; do
        local fname="${f##*/}"
        cexec bash -c "pacman --config ${PACMAN_CONF} -Udd --noconfirm --overwrite='*' /src/${pkg}/${fname}" 2>&1
    done
}

cmd_setup() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    msg "Setting up msys2-cross..."

    # Download sources
    if [[ ! -d "${SCRIPT_DIR}/sources" ]] || [[ -z "$(ls -A "${SCRIPT_DIR}/sources" 2>/dev/null)" ]]; then
        msg "Downloading toolchain sources..."
        bash "${SCRIPT_DIR}/scripts/download-sources.sh"
    else
        msg "Sources already downloaded"
    fi

    # Build container
    if [[ "$force" -eq 1 ]]; then
        msg "Force-rebuilding container..."
        podman rm -f "${CONTAINER_NAME}" 2>/dev/null || true
        podman build --no-cache -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    elif podman image exists "${IMAGE_NAME}"; then
        msg "Container image already exists (use --force to rebuild)"
    else
        msg "Building container (this takes 30-60 minutes)..."
        podman build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    fi

    # Clone MINGW-packages
    ensure_mingw_packages

    echo ""
    msg "Setup complete! Try:"
    echo "  ./msys2-cross build zlib"
    echo "  ./msys2-cross shell"
}

cmd_build() {
    local packages=()
    local makepkg_args=()

    for arg in "$@"; do
        case "$arg" in
            -*) makepkg_args+=("$arg") ;;
            *)  packages+=("$arg") ;;
        esac
    done

    if [[ ${#packages[@]} -eq 0 ]]; then
        err "Usage: msys2-cross build <pkg> [...] [makepkg flags]"
        exit 1
    fi

    # Always force and skip checks for cross-compilation
    makepkg_args+=("--skipchecksums" "--skippgpcheck" "--nocheck" "-sf")

    ensure_mingw_packages
    ensure_container

    for raw_pkg in "${packages[@]}"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")

        checkout_pkg "$pkg"

        # Resolve missing dependencies
        declare -A _resolve_visited=()
        _resolve_result=()
        resolve_deps "$pkg"
        local -a build_order=("${_resolve_result[@]}")

        # Build order includes the package itself as last entry.
        # Everything before it is a missing dep.
        if [[ ${#build_order[@]} -gt 1 ]]; then
            msg "Dependency build order:"
            for p in "${build_order[@]}"; do
                if [[ "$p" == "$pkg" ]]; then
                    echo "  ${p}  (target)"
                else
                    echo "  ${p}"
                fi
            done
        fi

        for dep_pkg in "${build_order[@]}"; do
            # Skip deps that are already installed
            if [[ "$dep_pkg" != "$pkg" ]]; then
                local dep_ipkg="mingw-w64-ucrt-x86_64-${dep_pkg#mingw-w64-}"
                if is_installed "$dep_ipkg"; then
                    msg "${dep_pkg} already installed, skipping"
                    continue
                fi
            fi

            build_single "$dep_pkg" "${makepkg_args[@]}"

            # Install deps (but not the final target package)
            if [[ "$dep_pkg" != "$pkg" ]]; then
                install_single "$dep_pkg" || warn "Failed to install ${dep_pkg}"
            fi
        done

        # Show result for the target package
        local built_pkgs
        built_pkgs=$(find "${MINGW_PACKAGES_DIR}/${pkg}" -name "*.pkg.tar.*" -newer "${MINGW_PACKAGES_DIR}/${pkg}/PKGBUILD" 2>/dev/null)
        if [[ -n "$built_pkgs" ]]; then
            msg "Built packages:"
            echo "$built_pkgs" | while read -r f; do echo "  ${f##*/}"; done
        fi
    done
}

cmd_install() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross install <pkg> [...]"
        exit 1
    fi

    ensure_container

    for raw_pkg in "$@"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")
        install_single "$pkg"
    done
}

cmd_deps() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross deps <pkg>"
        exit 1
    fi

    ensure_mingw_packages
    ensure_container

    local pkg
    pkg=$(normalize_pkg "$1")
    checkout_pkg "$pkg"

    declare -A _resolve_visited=()
    _resolve_result=()
    resolve_deps "$pkg"
    local -a build_order=("${_resolve_result[@]}")

    if [[ ${#build_order[@]} -le 1 ]]; then
        msg "All dependencies for ${pkg} are satisfied"
    else
        msg "Missing dependencies (build order):"
        for p in "${build_order[@]}"; do
            if [[ "$p" == "$pkg" ]]; then
                echo "  ${p}  (target)"
            else
                echo "  ${p}  (missing)"
            fi
        done
    fi
}

cmd_shell() {
    ensure_container
    msg "Entering msys2-cross shell (persistent container: ${CONTAINER_NAME})"
    echo "  Sysroot:  /ucrt64"
    echo "  Packages: /src"
    echo "  Compiler: x86_64-w64-mingw32-gcc"
    echo ""
    podman exec -it "${CONTAINER_NAME}" bash
}

cmd_run() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross run <command...>"
        exit 1
    fi
    ensure_container
    cexec "$@"
}

cmd_list() {
    ensure_container
    cexec pacman --config "${PACMAN_CONF}" -Q
}

cmd_rebuild() {
    msg "Rebuilding container image..."
    # Stop and remove persistent container if it exists
    podman rm -f "${CONTAINER_NAME}" 2>/dev/null || true
    podman build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    msg "Rebuild complete"
}

# --- Main ---
if [[ $# -eq 0 ]]; then
    usage
fi

case "$1" in
    setup)    shift; cmd_setup "$@" ;;
    build)    shift; cmd_build "$@" ;;
    install)  shift; cmd_install "$@" ;;
    deps)     shift; cmd_deps "$@" ;;
    shell)    shift; cmd_shell "$@" ;;
    run)      shift; cmd_run "$@" ;;
    list)     shift; cmd_list "$@" ;;
    rebuild)  shift; cmd_rebuild "$@" ;;
    help|-h|--help) usage 0 ;;
    *)        err "Unknown command: $1"; usage 1 ;;
esac
