#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BOOTSTRAP_IMAGE="msys2-cross"
WORK_IMAGE="msys2-cross-work"
MINGW_PACKAGES_DIR="${SCRIPT_DIR}/MINGW-packages"
PACMAN_CONF="/opt/msys2-cross/config/pacman-mingw.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

msg()  { echo -e "${GREEN}==>${NC} ${BOLD}$1${NC}"; }
warn() { echo -e "${YELLOW}==> WARNING:${NC} ${BOLD}$1${NC}"; }
err()  { echo -e "${RED}==> ERROR:${NC} ${BOLD}$1${NC}" >&2; }

usage() {
    cat <<'EOF'
Usage: msys2-cross <command> [args...]

Commands:
  setup [--force]       First-time setup: download sources, build bootstrap
                        image, clone MINGW-packages. --force rebuilds
  build <pkg> [...]     Build one or more MINGW packages (builds missing deps)
  install <pkg> [...]   Install built packages into the working image
  deps <pkg>            Show missing dependencies for a package
  shell [--network]     Open an interactive shell (--network enables network)
  run <cmd...>          Run an arbitrary command in the build environment
  list                  List installed packages in the sysroot
  list -u               List built but not installed packages
  list -a               List all packages known to cross-compile
  diff                  Show files changed in the working image vs bootstrap
  reset                 Remove working image (reset to bootstrap baseline)
  destroy               Remove working image, bootstrap image, and built packages
  rebuild               Rebuild the bootstrap image

Package names can omit the "mingw-w64-" prefix:
  msys2-cross build libpng    →  builds mingw-w64-libpng
EOF
    exit "${1:-0}"
}

# Normalize package name: "libpng" → "mingw-w64-libpng"
normalize_pkg() {
    local pkg="$1"
    if [[ "$pkg" != mingw-w64-* ]]; then
        pkg="mingw-w64-${pkg}"
    fi
    echo "$pkg"
}

# Ensure MINGW-packages is cloned
ensure_mingw_packages() {
    if [[ ! -d "${MINGW_PACKAGES_DIR}/.git" ]]; then
        msg "Cloning MINGW-packages (sparse)..."
        git clone --filter=blob:none --sparse \
            https://github.com/msys2/MINGW-packages.git \
            "${MINGW_PACKAGES_DIR}"
    fi
}

# Sparse checkout a package. Handles split packages by trying the
# base name if the full name doesn't exist (e.g., mingw-w64-gettext-runtime
# → mingw-w64-gettext).
checkout_pkg() {
    local pkg="$1"
    ensure_mingw_packages
    cd "${MINGW_PACKAGES_DIR}"
    if [[ ! -d "${pkg}" ]]; then
        git sparse-checkout add "${pkg}" 2>/dev/null
    fi
    if [[ ! -d "${pkg}" ]]; then
        for suffix in -runtime -tools -libs -devel -git; do
            local base="${pkg%${suffix}}"
            if [[ "$base" != "$pkg" ]]; then
                git sparse-checkout add "${base}" 2>/dev/null
                if [[ -d "${base}" ]]; then
                    _checkout_actual="${base}"
                    return 0
                fi
            fi
        done
        err "Package ${pkg} not found in MINGW-packages"
        return 1
    fi
    _checkout_actual="${pkg}"
}

# Ensure bootstrap image exists
ensure_image() {
    if ! podman image exists "${BOOTSTRAP_IMAGE}"; then
        err "Bootstrap image '${BOOTSTRAP_IMAGE}' not found. Run: msys2-cross setup"
        exit 1
    fi
}

# Return the current image to use (working if it exists, otherwise bootstrap)
current_image() {
    if podman image exists "${WORK_IMAGE}" 2>/dev/null; then
        echo "${WORK_IMAGE}"
    else
        echo "${BOOTSTRAP_IMAGE}"
    fi
}

# Run an ephemeral container against the current working image.
prun() {
    ensure_image
    podman run --rm \
        --network=none \
        -v "${MINGW_PACKAGES_DIR}:/src" \
        -v "${SCRIPT_DIR}/patches:/opt/msys2-cross/patches:ro" \
        -v "${SCRIPT_DIR}/config:/opt/msys2-cross/config:ro" \
        -v "${SCRIPT_DIR}/wrappers:/opt/msys2-cross/wrappers:ro" \
        "$(current_image)" "$@"
}

# Fix ownership of files created by the container
fix_ownership() {
    local dir="$1"
    if [[ -d "$dir" ]]; then
        podman unshare chown -R "$(id -u):$(id -g)" "$dir" 2>/dev/null || true
    fi
}

# Find missing MINGW deps for a package (direct only).
find_missing_deps() {
    local pkg="$1"

    checkout_pkg "$pkg" >/dev/null 2>&1

    prun bash -c "
        set +eu
        source /opt/msys2-cross/config/mingw-env.sh
        PACMAN_CONF=${PACMAN_CONF}

        tmpdir=\$(mktemp -d)
        cp /src/${pkg}/PKGBUILD \"\$tmpdir/PKGBUILD\"
        cd \"\$tmpdir\"

        _patch=/opt/msys2-cross/patches/${pkg}.sh
        [[ -f \"\$_patch\" ]] && source \"\$_patch\" 2>/dev/null

        source PKGBUILD 2>/dev/null
        for dep in \"\${depends[@]}\" \"\${makedepends[@]}\"; do
            dep=\"\${dep%%[><=]*}\"
            if [[ \"\$dep\" == mingw-w64-ucrt-x86_64-* ]]; then
                pacman --config \$PACMAN_CONF -Qq \"\$dep\" &>/dev/null || {
                    name=\"\${dep#mingw-w64-ucrt-x86_64-}\"
                    echo \"mingw-w64-\$name\"
                }
            fi
        done
        rm -rf \"\$tmpdir\"
    " 2>/dev/null | sort -u
}

# Recursively find all missing deps (transitive). Checkouts all needed
# packages on the host, then does the full walk in a single podman run.
# Returns source package names in topological (build) order.
find_all_missing_deps() {
    local root_pkg="$1"

    # First, checkout all packages we might need by doing a breadth-first
    # checkout on the host (fast git operations, no podman overhead).
    local -A checked_out=()
    local queue=("$root_pkg")
    while [[ ${#queue[@]} -gt 0 ]]; do
        local pkg="${queue[0]}"
        queue=("${queue[@]:1}")
        [[ -n "${checked_out[$pkg]+x}" ]] && continue
        checked_out[$pkg]=1
        checkout_pkg "$pkg" >/dev/null 2>&1 || continue
        if [[ -f "${MINGW_PACKAGES_DIR}/${pkg}/PKGBUILD" ]]; then
            grep -oP '\$\{MINGW_PACKAGE_PREFIX\}-\K[a-z0-9_-]+' \
                "${MINGW_PACKAGES_DIR}/${pkg}/PKGBUILD" 2>/dev/null | \
                sort -u | while read -r dep_name; do
                    local dep_pkg="mingw-w64-${dep_name}"
                    if [[ -z "${checked_out[$dep_pkg]+x}" ]]; then
                        echo "$dep_pkg"
                    fi
                done | while read -r p; do queue+=("$p"); done
        fi
    done

    prun bash -c "
        set +eu
        source /opt/msys2-cross/config/mingw-env.sh
        PACMAN_CONF=${PACMAN_CONF}

        get_deps() {
            local srcpkg=\$1
            [[ -d /src/\$srcpkg ]] || return

            local tmpdir=\$(mktemp -d)
            cp /src/\$srcpkg/PKGBUILD \"\$tmpdir/PKGBUILD\"
            cd \"\$tmpdir\"

            local _patch=/opt/msys2-cross/patches/\${srcpkg}.sh
            [[ -f \"\$_patch\" ]] && source \"\$_patch\" 2>/dev/null

            source PKGBUILD 2>/dev/null
            for dep in \"\${depends[@]}\" \"\${makedepends[@]}\"; do
                dep=\"\${dep%%[><=]*}\"
                if [[ \"\$dep\" == mingw-w64-ucrt-x86_64-* ]]; then
                    echo \"\$dep\"
                fi
            done
            rm -rf \"\$tmpdir\"
            cd /
        }

        declare -A visited=()
        result=()

        resolve() {
            local srcpkg=\$1
            [[ -n \"\${visited[\$srcpkg]+x}\" ]] && return
            visited[\$srcpkg]=1

            local deps=\$(get_deps \"\$srcpkg\" | sort -u)
            for dep in \$deps; do
                pacman --config \$PACMAN_CONF -Qq \"\$dep\" &>/dev/null && continue
                local name=\"\${dep#mingw-w64-ucrt-x86_64-}\"
                local child=\"mingw-w64-\$name\"
                resolve \"\$child\"
            done

            local ipkg=\"mingw-w64-ucrt-x86_64-\${srcpkg#mingw-w64-}\"
            if ! pacman --config \$PACMAN_CONF -Qq \"\$ipkg\" &>/dev/null; then
                result+=(\"\$srcpkg\")
            fi
        }

        resolve \"${root_pkg}\"

        for p in \"\${result[@]}\"; do
            echo \"\$p\"
        done
    " 2>/dev/null
}

# Download sources for a single package
download_sources() {
    local pkg="$1"
    msg "Downloading sources for ${pkg}..."
    podman run --rm \
        -v "${MINGW_PACKAGES_DIR}/${pkg}:/pkg" \
        "${BOOTSTRAP_IMAGE}" \
        bash -c "
            source /opt/msys2-cross/config/mingw-env.sh
            useradd -m builduser 2>/dev/null || true
            chown -R builduser: /pkg
            su builduser -s /bin/bash -c 'cd /pkg && makepkg --verifysource --skipchecksums --skippgpcheck --config /opt/msys2-cross/config/makepkg_mingw.conf --nodeps -f'
        "
    fix_ownership "${MINGW_PACKAGES_DIR}/${pkg}"
}

# Build a single package (no dep resolution)
build_single() {
    local pkg="$1"
    shift
    local makepkg_args=("$@")

    checkout_pkg "$pkg"
    download_sources "$pkg"

    msg "Building ${pkg}..."
    prun bash -c "
        rm -rf /tmp/build/${pkg}
        mkdir -p /tmp/build
        cp -a /src/${pkg} /tmp/build/${pkg}
        cd /tmp/build/${pkg}
        makepkg-mingw ${makepkg_args[*]}
        _rc=\$?
        cp -f /tmp/build/${pkg}/*.pkg.tar.* /src/${pkg}/ 2>/dev/null || true
        exit \$_rc
    "
    local rc=$?
    fix_ownership "${MINGW_PACKAGES_DIR}/${pkg}"
    return $rc
}

# Install packages and commit the result as the working image.
install_single() {
    local pkg="$1"

    local pkgfiles
    pkgfiles=$(find "${MINGW_PACKAGES_DIR}/${pkg}" -name "*.pkg.tar.*" 2>/dev/null | head -20)

    if [[ -z "$pkgfiles" ]]; then
        err "No built packages found for ${pkg}"
        return 1
    fi

    # Check if all packages are already installed (skip needless commits)
    local to_install=()
    for f in $pkgfiles; do
        local fname="${f##*/}"
        # Extract package name from filename (strip version-release-arch.pkg.tar.*)
        local pname
        pname=$(echo "$fname" | sed 's/-[0-9].*$//')
        if prun pacman --config "${PACMAN_CONF}" -Qq "${pname}" &>/dev/null; then
            warn "${pname} already installed, skipping"
        else
            to_install+=("$fname")
        fi
    done

    if [[ ${#to_install[@]} -eq 0 ]]; then
        return 0
    fi

    msg "Installing ${pkg}..."
    local container="msys2-cross-install-$$"
    local image
    image="$(current_image)"

    local install_cmds=""
    for fname in "${to_install[@]}"; do
        install_cmds+="pacman --config ${PACMAN_CONF} -Udd --noconfirm --overwrite='*' /src/${pkg}/${fname} && "
    done
    install_cmds+="true"

    podman run \
        --name "${container}" \
        --network=none \
        -v "${MINGW_PACKAGES_DIR}:/src" \
        -v "${SCRIPT_DIR}/patches:/opt/msys2-cross/patches:ro" \
        -v "${SCRIPT_DIR}/config:/opt/msys2-cross/config:ro" \
        -v "${SCRIPT_DIR}/wrappers:/opt/msys2-cross/wrappers:ro" \
        "${image}" bash -c "${install_cmds}" 2>&1
    local rc=$?

    if [[ $rc -eq 0 ]]; then
        podman commit -q "${container}" "${WORK_IMAGE}" >/dev/null
    fi
    podman rm -f "${container}" >/dev/null 2>&1
    return $rc
}

cmd_setup() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    msg "Setting up msys2-cross..."

    # Download sources
    if [[ ! -d "${SCRIPT_DIR}/sources" ]] || [[ -z "$(ls -A "${SCRIPT_DIR}/sources" 2>/dev/null)" ]]; then
        msg "Downloading toolchain sources..."
        bash "${SCRIPT_DIR}/scripts/download-sources.sh"
    else
        msg "Sources already downloaded"
    fi

    # Build bootstrap image
    if [[ "$force" -eq 1 ]]; then
        msg "Force-rebuilding bootstrap image..."
        podman rmi -f "${WORK_IMAGE}" 2>/dev/null || true
        TMPDIR=/var/tmp podman build -t "${BOOTSTRAP_IMAGE}" "${SCRIPT_DIR}"
    elif podman image exists "${BOOTSTRAP_IMAGE}"; then
        msg "Bootstrap image already exists (use --force to rebuild)"
    else
        msg "Building bootstrap image (this takes 30-60 minutes)..."
        TMPDIR=/var/tmp podman build -t "${BOOTSTRAP_IMAGE}" "${SCRIPT_DIR}"
    fi

    # Clone MINGW-packages
    ensure_mingw_packages

    echo ""
    msg "Setup complete! Try:"
    echo "  ./msys2-cross build zlib"
    echo "  ./msys2-cross shell"
}

cmd_build() {
    local packages=()
    local makepkg_args=()

    for arg in "$@"; do
        case "$arg" in
            -*) makepkg_args+=("$arg") ;;
            *)  packages+=("$arg") ;;
        esac
    done

    if [[ ${#packages[@]} -eq 0 ]]; then
        err "Usage: msys2-cross build <pkg> [...] [makepkg flags]"
        exit 1
    fi

    # Always force and skip checks for cross-compilation
    makepkg_args+=("--skipchecksums" "--skippgpcheck" "--nocheck" "-sf")

    ensure_mingw_packages

    local -a succeeded=()
    local -a failed=()

    for raw_pkg in "${packages[@]}"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")

        checkout_pkg "$pkg"

        # Resolve all missing transitive dependencies
        local missing
        missing=$(find_all_missing_deps "$pkg")

        if [[ -n "$missing" ]]; then
            local count
            count=$(echo "$missing" | wc -l)
            msg "Building ${count} packages (including dependencies):"
            for dep in $missing; do echo "  ${dep}"; done

            for dep in $missing; do
                checkout_pkg "$dep" 2>/dev/null || { warn "Cannot find ${dep}, skipping"; failed+=("$dep"); continue; }
                local dep_src="${_checkout_actual}"
                if build_single "$dep_src" "${makepkg_args[@]}"; then
                    succeeded+=("$dep_src")
                    # Install deps (not the final target) so later builds find them
                    if [[ "$dep_src" != "$pkg" ]]; then
                        install_single "$dep_src" || warn "Failed to install ${dep_src}"
                    fi
                else
                    failed+=("$dep_src")
                fi
            done
        else
            # No missing deps — just build the target
            if build_single "$pkg" "${makepkg_args[@]}"; then
                succeeded+=("$pkg")
            else
                failed+=("$pkg")
            fi
        fi
    done

    # Summary
    echo ""
    if [[ ${#succeeded[@]} -gt 0 ]]; then
        msg "Succeeded (${#succeeded[@]}):"
        for p in "${succeeded[@]}"; do
            local pkgs
            pkgs=$(find "${MINGW_PACKAGES_DIR}/${p}" -name "*.pkg.tar.*" 2>/dev/null)
            if [[ -n "$pkgs" ]]; then
                echo "$pkgs" | while read -r f; do echo -e "  ${GREEN}OK${NC}  ${f##*/}"; done
            else
                echo -e "  ${GREEN}OK${NC}  ${p}"
            fi
        done
    fi
    if [[ ${#failed[@]} -gt 0 ]]; then
        err "Failed (${#failed[@]}):"
        for p in "${failed[@]}"; do echo -e "  ${RED}FAIL${NC}  ${p}"; done
    fi
}

cmd_install() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross install <pkg> [...]"
        exit 1
    fi

    for raw_pkg in "$@"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")
        install_single "$pkg"
    done
}

cmd_deps() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross deps <pkg>"
        exit 1
    fi

    ensure_mingw_packages

    local pkg
    pkg=$(normalize_pkg "$1")
    checkout_pkg "$pkg"

    local missing
    missing=$(find_all_missing_deps "$pkg")

    if [[ -z "$missing" ]]; then
        msg "All dependencies for ${pkg} are satisfied"
    else
        local count
        count=$(echo "$missing" | wc -l)
        msg "Missing dependencies for ${pkg} (${count}, build order):"
        for p in $missing; do
            if [[ "$p" == "$pkg" ]]; then
                echo "  ${p}  (target)"
            else
                echo "  ${p}"
            fi
        done
    fi
}

cmd_shell() {
    local network="none"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --network) network="pasta"; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    ensure_image
    local image
    image="$(current_image)"
    msg "Entering msys2-cross shell (image=${image}, network=${network})"
    echo "  Sysroot:  /ucrt64"
    echo "  Packages: /src"
    echo "  Compiler: x86_64-w64-mingw32-gcc"
    echo ""
    podman run --rm -it \
        --network="${network}" \
        -v "${MINGW_PACKAGES_DIR}:/src" \
        -v "${SCRIPT_DIR}/patches:/opt/msys2-cross/patches:ro" \
        -v "${SCRIPT_DIR}/config:/opt/msys2-cross/config:ro" \
        -v "${SCRIPT_DIR}/wrappers:/opt/msys2-cross/wrappers:ro" \
        "${image}" bash
}

cmd_run() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross run <command...>"
        exit 1
    fi
    prun "$@"
}

cmd_list() {
    case "${1:-}" in
        -u)
            # List built but not installed packages
            msg "Built packages not installed in sysroot:"
            local installed
            installed=$(prun pacman --config "${PACMAN_CONF}" -Q 2>/dev/null | awk '{print $1}')
            find "${MINGW_PACKAGES_DIR}" -name "*.pkg.tar.*" 2>/dev/null | while read -r f; do
                local fname="${f##*/}"
                local pname
                pname=$(echo "$fname" | sed 's/-[0-9].*$//')
                if ! echo "$installed" | grep -qx "$pname"; then
                    echo "  ${fname}"
                fi
            done
            ;;
        -a)
            # List all available packages from MINGW-packages repo
            ensure_mingw_packages
            msg "Available packages in MINGW-packages:"
            cd "${MINGW_PACKAGES_DIR}"
            git ls-tree -r --name-only HEAD | grep "^mingw-w64-.*/PKGBUILD$" | sed 's|/PKGBUILD||' | sort | while read -r pkg; do
                local marker=""
                if [[ -f "${SCRIPT_DIR}/patches/${pkg}.sh" ]]; then
                    marker=" [patched]"
                fi
                echo "  ${pkg}${marker}"
            done
            ;;
        *)
            prun pacman --config "${PACMAN_CONF}" -Q
            ;;
    esac
}

cmd_diff() {
    ensure_image
    if ! podman image exists "${WORK_IMAGE}" 2>/dev/null; then
        msg "No working image — nothing changed from bootstrap"
        return
    fi
    msg "Changes in working image vs bootstrap:"
    local bootstrap_pkgs work_pkgs
    bootstrap_pkgs=$(podman run --rm "${BOOTSTRAP_IMAGE}" pacman --config "${PACMAN_CONF}" -Q 2>/dev/null)
    work_pkgs=$(podman run --rm "${WORK_IMAGE}" pacman --config "${PACMAN_CONF}" -Q 2>/dev/null)
    local output
    output=$(diff <(echo "$bootstrap_pkgs") <(echo "$work_pkgs") | grep '^[<>]' | sed -e 's/^> /  + /' -e 's/^< /  - /' || true)
    if [[ -z "$output" ]]; then
        echo "  (no package changes)"
    else
        echo "$output"
    fi
}

cmd_reset() {
    if podman image exists "${WORK_IMAGE}" 2>/dev/null; then
        podman rmi -f "${WORK_IMAGE}" >/dev/null
        msg "Working image removed. Next run uses bootstrap baseline."
    else
        msg "No working image to reset"
    fi
}

cmd_destroy() {
    msg "Destroying msys2-cross environment..."
    podman rmi -f "${WORK_IMAGE}" 2>/dev/null && msg "Removed working image" || true
    podman rmi -f "${BOOTSTRAP_IMAGE}" 2>/dev/null && msg "Removed bootstrap image" || true

    # Clean built packages from MINGW-packages checkout
    local count
    count=$(find "${MINGW_PACKAGES_DIR}" -name "*.pkg.tar.*" 2>/dev/null | wc -l)
    if [[ "$count" -gt 0 ]]; then
        find "${MINGW_PACKAGES_DIR}" -name "*.pkg.tar.*" -delete
        msg "Removed ${count} built package(s) from ${MINGW_PACKAGES_DIR}"
    fi

    msg "Destroyed. Run 'msys2-cross setup' to start fresh."
}

cmd_rebuild() {
    msg "Rebuilding bootstrap image..."
    podman rmi -f "${WORK_IMAGE}" 2>/dev/null || true
    TMPDIR=/var/tmp podman build -t "${BOOTSTRAP_IMAGE}" "${SCRIPT_DIR}"
    msg "Rebuild complete."
}

# --- Main ---
if [[ $# -eq 0 ]]; then
    usage
fi

case "$1" in
    setup)    shift; cmd_setup "$@" ;;
    build)    shift; cmd_build "$@" ;;
    install)  shift; cmd_install "$@" ;;
    deps)     shift; cmd_deps "$@" ;;
    shell)    shift; cmd_shell "$@" ;;
    run)      shift; cmd_run "$@" ;;
    list)     shift; cmd_list "$@" ;;
    diff)     shift; cmd_diff "$@" ;;
    reset)    shift; cmd_reset "$@" ;;
    destroy)  shift; cmd_destroy "$@" ;;
    rebuild)  shift; cmd_rebuild "$@" ;;
    help|-h|--help) usage 0 ;;
    *)        err "Unknown command: $1"; usage 1 ;;
esac
