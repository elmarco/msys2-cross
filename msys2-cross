#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
REPO_DIR="${SCRIPT_DIR}"
source "${SCRIPT_DIR}/scripts/lib-mingw-pkg.sh"

# Parse --msystem early (before command dispatch)
_msys2_cross_args=()
for arg in "$@"; do
    case "$arg" in
        --msystem=*) export MSYSTEM="${arg#--msystem=}" ;;
        *) _msys2_cross_args+=("$arg") ;;
    esac
done
set -- "${_msys2_cross_args[@]}"

# Source environment config (uses MSYSTEM, defaults to UCRT64)
source "${SCRIPT_DIR}/scripts/env-config.sh"

BOOTSTRAP_IMAGE="msys2-cross-${MSYSTEM_LOWER}"
WORK_IMAGE="msys2-cross-${MSYSTEM_LOWER}-work"
PACMAN_CONF="/opt/msys2-cross/config/pacman-mingw.conf"
LOG_DIR="${SCRIPT_DIR}/logs"

build_image() {
    TMPDIR=/var/tmp podman build \
        --build-arg MSYSTEM="${MSYSTEM}" \
        --build-arg MINGW_PREFIX="${MINGW_PREFIX}" \
        --build-arg TARGET="${TARGET}" \
        --build-arg CC_FAMILY="${CC_FAMILY}" \
        --build-arg RUST_TARGET="${RUST_TARGET}" \
        --build-arg MINGW_PACKAGE_PREFIX="${MINGW_PACKAGE_PREFIX}" \
        -t "${BOOTSTRAP_IMAGE}" "${SCRIPT_DIR}"
}

# Common bind mounts for all container runs
CARGO_REGISTRY="${CARGO_HOME:-$HOME/.cargo}/registry"
VOLUMES=(
    -v "${MINGW_PACKAGES_DIR}:/src"
    -v "${SCRIPT_DIR}/patches:/opt/msys2-cross/patches:ro"
    -v "${SCRIPT_DIR}/config:/opt/msys2-cross/config:ro"
    -v "${SCRIPT_DIR}/wrappers:/opt/msys2-cross/wrappers:ro"
    -v "${SCRIPT_DIR}/scripts:/opt/msys2-cross/scripts:ro"
)
if [[ -d "${CARGO_REGISTRY}" ]]; then
    VOLUMES+=(-v "${CARGO_REGISTRY}:/home/builduser/.cargo/registry:ro")
fi

usage() {
    cat <<'EOF'
Usage: msys2-cross [--msystem=ENV] <command> [args...]

Environment (default: UCRT64):
  --msystem=UCRT64      GCC cross-compiler for x86_64 (default)
  --msystem=CLANG64     Clang/LLVM cross-compiler for x86_64
  --msystem=CLANGARM64  Clang/LLVM cross-compiler for aarch64

Commands:
  setup [--force]       First-time setup: download sources, build bootstrap
                        image, clone MINGW-packages. --force rebuilds
  download <pkg> [...]  Download sources for packages (runs on host)
  build <pkg> [...]     Build one or more MINGW packages (builds missing deps)
  install <pkg> [...]   Install built packages into the working image
  deps <pkg>            Show missing dependencies for a package
  describe <pkg>        Show package info (version, deps, status)
  srpm <pkg> [outdir]   Generate an SRPM for a MINGW package
  mock-build            Build the msys2-cross RPM via mock
  shell [--network]     Open an interactive shell in the current directory
  run [--network] <cmd...>  Run a command in the current directory
  list                  List installed packages in the sysroot
  list -u               List built but not installed packages
  list -a               List all packages known to cross-compile
  diff                  Show files changed in the working image vs bootstrap
  reset                 Remove working image (reset to bootstrap baseline)
  destroy               Remove working image, bootstrap image, and built packages
  rebuild               Rebuild the bootstrap image
  upstream install <pkg> Install pre-built packages from upstream MSYS2 repos
  upstream install-dep <pkg>
                        Install all build dependencies for <pkg> from upstream
  upstream search <pat>  Search upstream MSYS2 repos for packages
  check-update          Check for version drift against upstream MSYS2
  link [dir]            Symlink msys2-cross into dir (default: ~/.local/bin)
  complete zsh          Output shell code to load Zsh completions
                        Usage: eval "$(msys2-cross complete zsh)"

Package names can omit the "mingw-w64-" prefix:
  msys2-cross build libpng    →  builds mingw-w64-libpng
  msys2-cross upstream install libpng
                              →  installs mingw-w64-ucrt-x86_64-libpng
EOF
    exit "${1:-0}"
}

# Ensure bootstrap image exists
ensure_image() {
    if ! podman image exists "${BOOTSTRAP_IMAGE}"; then
        err "Bootstrap image '${BOOTSTRAP_IMAGE}' not found. Run: msys2-cross setup"
        exit 1
    fi
}

# Return the current image to use (working if it exists, otherwise bootstrap)
current_image() {
    if podman image exists "${WORK_IMAGE}" 2>/dev/null; then
        echo "${WORK_IMAGE}"
    else
        echo "${BOOTSTRAP_IMAGE}"
    fi
}

# Run an ephemeral container against the current working image.
# Flags: --network (enable network), --interactive (add -it)
prun() {
    local network="none"
    local -a extra_args=()
    while [[ "${1:-}" == --* ]]; do
        case "$1" in
            --network)     network="pasta"; shift ;;
            --interactive) extra_args+=(-it); shift ;;
            --workdir)     extra_args+=(-v "${PWD}:/work" --workdir /work); shift ;;
            *) break ;;
        esac
    done
    ensure_image
    podman run --rm --init \
        --userns=keep-id \
        --network="${network}" \
        "${extra_args[@]}" \
        "${VOLUMES[@]}" \
        "$(current_image)" "$@"
}

# Recursively find all missing deps (transitive). Iteratively runs the
# container-side resolver, checks out any packages it requests, and
# re-runs until no new checkouts are needed.
# Returns source package names in topological (build) order.
find_all_missing_deps() {
    local root_pkg="$1"
    local max_iterations=20

    for (( i=1; i<=max_iterations; i++ )); do
        local stderr_file
        stderr_file=$(mktemp)

        local result
        result=$(prun bash /opt/msys2-cross/scripts/resolve-deps.sh "${root_pkg}" 2>"${stderr_file}") || true

        local needed
        needed=$(grep '^NEED_CHECKOUT:' "${stderr_file}" | sed 's/^NEED_CHECKOUT://' | sort -u)
        rm -f "${stderr_file}"

        if [[ -z "$needed" ]]; then
            echo "$result"
            return
        fi

        local checked_out_any=0
        for pkg in $needed; do
            if checkout_pkg "$pkg" >/dev/null 2>&1; then
                checked_out_any=1
            fi
        done

        if [[ "$checked_out_any" -eq 0 ]]; then
            echo "$result"
            return
        fi
    done

    warn "Dependency resolution did not converge after ${max_iterations} iterations"
    echo "$result"
}

cmd_download() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross download <pkg> [...]"
        exit 1
    fi

    ensure_mingw_packages

    for raw_pkg in "$@"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")
        checkout_pkg "$pkg"
        download_sources "$pkg"
    done
}

# Build a single package (no dep resolution)
build_single() {
    local pkg="$1"
    shift
    local makepkg_args=("$@")

    checkout_pkg "$pkg"
    download_sources "$pkg"

    mkdir -p "${LOG_DIR}"
    local logfile="${LOG_DIR}/${pkg}_$(date +%Y%m%d-%H%M%S).log"

    msg "Building ${pkg}..."
    msg "Log: ${logfile}"
    prun bash -c "
        rm -rf /tmp/build/${pkg}
        mkdir -p /tmp/build
        cp -a /src/${pkg} /tmp/build/${pkg}
        cd /tmp/build/${pkg}
        makepkg-mingw ${makepkg_args[*]}
        _rc=\$?
        cp -f /tmp/build/${pkg}/*.pkg.tar.* /src/${pkg}/ 2>/dev/null || true
        exit \$_rc
    " 2>&1 | tee "${logfile}"
    local rc=${PIPESTATUS[0]}

    if [[ $rc -ne 0 ]]; then
        err "Build failed for ${pkg} — full log: ${logfile}"
    fi
    return $rc
}

# Install packages and commit the result as the working image.
install_single() {
    local pkg="$1"
    local force=0
    [[ "${2:-}" == "--force" ]] && force=1

    local pkgfiles
    pkgfiles=$(find "${MINGW_PACKAGES_DIR}/${pkg}" -name "${MINGW_PACKAGE_PREFIX}-*.pkg.tar.*" 2>/dev/null | head -20)

    if [[ -z "$pkgfiles" ]]; then
        err "No built packages found for ${pkg}"
        return 1
    fi

    # Check if all packages are already installed (skip needless commits)
    local to_install=()
    for f in $pkgfiles; do
        local fname="${f##*/}"
        local pname
        pname=$(echo "$fname" | sed 's/-[0-9].*$//')
        if [[ "$force" -eq 0 ]] && prun pacman --config "${PACMAN_CONF}" -Qq "${pname}" &>/dev/null; then
            warn "${pname} already installed, skipping"
        else
            to_install+=("$fname")
        fi
    done

    if [[ ${#to_install[@]} -eq 0 ]]; then
        return 0
    fi

    msg "Installing ${pkg}..."
    local container="msys2-cross-install-$$"
    local image
    image="$(current_image)"

    local install_cmds=""
    for fname in "${to_install[@]}"; do
        install_cmds+="pacman --config ${PACMAN_CONF} -Udd --noconfirm --overwrite='*' /src/${pkg}/${fname} && "
    done
    install_cmds+="true"

    podman run --init \
        --name "${container}" \
        --network=none \
        --user root \
        "${VOLUMES[@]}" \
        "${image}" bash -c "${install_cmds}" 2>&1
    local rc=$?

    if [[ $rc -eq 0 ]]; then
        podman commit -q --change 'USER builduser' "${container}" "${WORK_IMAGE}" >/dev/null
    fi
    podman rm -f "${container}" >/dev/null 2>&1
    return $rc
}

cmd_setup() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=1; shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    msg "Setting up msys2-cross [${MSYSTEM}]..."

    # Download sources
    if [[ ! -d "${SCRIPT_DIR}/sources" ]] || [[ -z "$(ls -A "${SCRIPT_DIR}/sources" 2>/dev/null)" ]]; then
        msg "Downloading toolchain sources..."
        bash "${SCRIPT_DIR}/scripts/download-sources.sh"
    else
        msg "Sources already downloaded"
    fi

    # Build bootstrap image
    if [[ "$force" -eq 1 ]]; then
        msg "Force-rebuilding bootstrap image..."
        podman rmi -f "${WORK_IMAGE}" 2>/dev/null || true
        build_image
    elif podman image exists "${BOOTSTRAP_IMAGE}"; then
        msg "Bootstrap image already exists (use --force to rebuild)"
    else
        msg "Building bootstrap image (this takes 30-60 minutes)..."
        build_image
    fi

    # Clone MINGW-packages
    ensure_mingw_packages

    echo ""
    msg "Setup complete! Try:"
    echo "  ./msys2-cross build zlib"
    echo "  ./msys2-cross shell"
}

cmd_build() {
    local packages=()
    local makepkg_args=()
    local keep_going=0

    for arg in "$@"; do
        case "$arg" in
            -k|--keep-going) keep_going=1 ;;
            -*) makepkg_args+=("$arg") ;;
            *)  packages+=("$arg") ;;
        esac
    done

    if [[ ${#packages[@]} -eq 0 ]]; then
        err "Usage: msys2-cross build <pkg> [...] [makepkg flags]"
        exit 1
    fi

    makepkg_args+=("--skipchecksums" "--nodeps" "-f")

    ensure_mingw_packages

    local -a succeeded=()
    local -a failed=()

    for raw_pkg in "${packages[@]}"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")

        checkout_pkg "$pkg"

        # Resolve all missing transitive dependencies
        local all_deps
        all_deps=$(find_all_missing_deps "$pkg")

        # Split into build order and cycle-rebuild list
        local missing rebuild
        missing=$(echo "$all_deps" | sed '/^---rebuild---$/,$d')
        rebuild=$(echo "$all_deps" | sed -n '/^---rebuild---$/,$ { /^---rebuild---$/d; p; }')

        if [[ -n "$missing" ]]; then
            local count
            count=$(echo "$missing" | wc -l)
            msg "Building ${count} packages (including dependencies):"
            for dep in $missing; do echo "  ${dep}"; done

            for dep in $missing; do
                checkout_pkg "$dep" 2>/dev/null || { warn "Cannot find ${dep}, skipping"; failed+=("$dep"); [[ "$keep_going" -eq 1 ]] && continue || break 2; }
                local dep_src="${_checkout_actual}"
                if build_single "$dep_src" "${makepkg_args[@]}"; then
                    succeeded+=("$dep_src")
                    # Install deps (not the final target) so later builds find them
                    if [[ "$dep_src" != "$pkg" ]]; then
                        install_single "$dep_src" || warn "Failed to install ${dep_src}"
                    fi
                else
                    failed+=("$dep_src")
                    if [[ "$keep_going" -eq 0 ]]; then
                        err "Stopping at first failure (use -k to keep going)"
                        break 2
                    fi
                fi
            done

            # Rebuild cycle members so they get full feature support
            if [[ -n "$rebuild" && ${#failed[@]} -eq 0 ]]; then
                # Install the target so rebuild deps can link against it
                install_single "$pkg" || warn "Failed to install ${pkg}"

                local rebuild_count
                rebuild_count=$(echo "$rebuild" | wc -l)
                msg "Rebuilding ${rebuild_count} cycle member(s) with full dependencies:"
                for dep in $rebuild; do echo "  ${dep} (rebuild)"; done

                for dep in $rebuild; do
                    checkout_pkg "$dep" 2>/dev/null || continue
                    local dep_src="${_checkout_actual}"
                    if build_single "$dep_src" "${makepkg_args[@]}"; then
                        succeeded+=("$dep_src")
                        install_single "$dep_src" --force || warn "Failed to reinstall ${dep_src}"
                    else
                        failed+=("$dep_src")
                        if [[ "$keep_going" -eq 0 ]]; then
                            err "Stopping at first failure (use -k to keep going)"
                            break 2
                        fi
                    fi
                done
            fi
        else
            # No missing deps — just build the target
            if build_single "$pkg" "${makepkg_args[@]}"; then
                succeeded+=("$pkg")
            else
                failed+=("$pkg")
            fi
        fi
    done

    # Summary
    echo ""
    if [[ ${#succeeded[@]} -gt 0 ]]; then
        msg "Succeeded (${#succeeded[@]}):"
        for p in "${succeeded[@]}"; do
            local pkgs
            pkgs=$(find "${MINGW_PACKAGES_DIR}/${p}" -name "${MINGW_PACKAGE_PREFIX}-*.pkg.tar.*" 2>/dev/null)
            if [[ -n "$pkgs" ]]; then
                echo "$pkgs" | while read -r f; do echo -e "  ${GREEN}OK${NC}  ${f##*/}"; done
            else
                echo -e "  ${GREEN}OK${NC}  ${p}"
            fi
        done
    fi
    if [[ ${#failed[@]} -gt 0 ]]; then
        err "Failed (${#failed[@]}):"
        for p in "${failed[@]}"; do echo -e "  ${RED}FAIL${NC}  ${p}"; done
    fi
}

cmd_install() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross install <pkg> [...]"
        exit 1
    fi

    for raw_pkg in "$@"; do
        local pkg
        pkg=$(normalize_pkg "$raw_pkg")
        install_single "$pkg"
    done
}

cmd_deps() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross deps <pkg>"
        exit 1
    fi

    ensure_mingw_packages

    local pkg
    pkg=$(normalize_pkg "$1")
    checkout_pkg "$pkg"

    local missing
    missing=$(find_all_missing_deps "$pkg")

    if [[ -z "$missing" ]]; then
        msg "All dependencies for ${pkg} are satisfied"
    else
        local count
        count=$(echo "$missing" | wc -l)
        msg "Missing dependencies for ${pkg} (${count}, build order):"
        for p in $missing; do
            if [[ "$p" == "$pkg" ]]; then
                echo "  ${p}  (target)"
            else
                echo "  ${p}"
            fi
        done
    fi
}

cmd_shell() {
    local prun_args=(--interactive --workdir)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --network) prun_args+=(--network); shift ;;
            *) err "Unknown option: $1"; exit 1 ;;
        esac
    done

    ensure_image
    local image
    image="$(current_image)"
    msg "Entering msys2-cross shell [${MSYSTEM}] (image=${image})"
    echo "  Sysroot:  ${MINGW_PREFIX}"
    echo "  Packages: /src"
    echo "  Workdir:  /work (${PWD})"
    echo "  Compiler: ${CROSS_CC}"
    echo ""
    echo "  Run: source /opt/msys2-cross/config/mingw-env.sh"
    echo ""
    prun "${prun_args[@]}" bash
}

cmd_run() {
    local prun_args=(--workdir)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --network) prun_args+=("--network"); shift ;;
            *) break ;;
        esac
    done
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross run [--network] <command...>"
        exit 1
    fi
    prun "${prun_args[@]}" bash -c "$*"
}

cmd_list() {
    case "${1:-}" in
        -u)
            msg "Built packages not installed in sysroot:"
            local installed
            installed=$(prun pacman --config "${PACMAN_CONF}" -Q 2>/dev/null | awk '{print $1}')
            find "${MINGW_PACKAGES_DIR}" -name "*.pkg.tar.*" 2>/dev/null | while read -r f; do
                local fname="${f##*/}"
                local pname
                pname=$(echo "$fname" | sed 's/-[0-9].*$//')
                if ! echo "$installed" | grep -qx "$pname"; then
                    echo "  ${fname}"
                fi
            done
            ;;
        -a)
            ensure_mingw_packages
            msg "Available packages in MINGW-packages:"
            cd "${MINGW_PACKAGES_DIR}"
            git ls-tree -r --name-only HEAD | grep "^mingw-w64-.*/PKGBUILD$" | sed 's|/PKGBUILD||' | sort | while read -r pkg; do
                local marker=""
                if [[ -f "${SCRIPT_DIR}/patches/${pkg}.sh" ]]; then
                    marker=" [patched]"
                fi
                echo "  ${pkg}${marker}"
            done
            ;;
        *)
            prun pacman --config "${PACMAN_CONF}" -Q
            ;;
    esac
}

cmd_diff() {
    ensure_image
    if ! podman image exists "${WORK_IMAGE}" 2>/dev/null; then
        msg "No working image — nothing changed from bootstrap"
        return
    fi
    msg "Changes in working image vs bootstrap:"
    local bootstrap_pkgs work_pkgs
    bootstrap_pkgs=$(podman run --rm "${BOOTSTRAP_IMAGE}" pacman --config "${PACMAN_CONF}" -Q 2>/dev/null)
    work_pkgs=$(podman run --rm "${WORK_IMAGE}" pacman --config "${PACMAN_CONF}" -Q 2>/dev/null)
    local output
    output=$(diff <(echo "$bootstrap_pkgs") <(echo "$work_pkgs") | grep '^[<>]' | sed -e 's/^> /  + /' -e 's/^< /  - /' || true)
    if [[ -z "$output" ]]; then
        echo "  (no package changes)"
    else
        echo "$output"
    fi
}

cmd_reset() {
    if podman image exists "${WORK_IMAGE}" 2>/dev/null; then
        podman rmi -f "${WORK_IMAGE}" >/dev/null
        msg "Working image removed. Next run uses bootstrap baseline."
    else
        msg "No working image to reset"
    fi
}

cmd_destroy() {
    msg "Destroying msys2-cross environment..."
    podman rmi -f "${WORK_IMAGE}" 2>/dev/null && msg "Removed working image" || true
    podman rmi -f "${BOOTSTRAP_IMAGE}" 2>/dev/null && msg "Removed bootstrap image" || true

    local count
    count=$(find "${MINGW_PACKAGES_DIR}" -name "*.pkg.tar.*" 2>/dev/null | wc -l)
    if [[ "$count" -gt 0 ]]; then
        find "${MINGW_PACKAGES_DIR}" -name "*.pkg.tar.*" -delete
        msg "Removed ${count} built package(s) from ${MINGW_PACKAGES_DIR}"
    fi

    msg "Destroyed. Run 'msys2-cross setup' to start fresh."
}

cmd_rebuild() {
    msg "Rebuilding bootstrap image..."
    podman rmi -f "${WORK_IMAGE}" 2>/dev/null || true
    build_image
    msg "Rebuild complete."
}

cmd_link() {
    local link_dir="${1:-${HOME}/.local/bin}"
    local link_path="${link_dir}/msys2-cross"
    local target="${SCRIPT_DIR}/msys2-cross"

    if [[ -L "${link_path}" ]]; then
        local existing
        existing="$(readlink -f "${link_path}")"
        if [[ "${existing}" == "${target}" ]]; then
            msg "Already linked: ${link_path} → ${target}"
            return 0
        fi
        msg "Updating existing symlink (was → ${existing})"
    elif [[ -e "${link_path}" ]]; then
        err "${link_path} already exists and is not a symlink"
        exit 1
    fi

    mkdir -p "${link_dir}"
    ln -sf "${target}" "${link_path}"
    msg "Linked: ${link_path} → ${target}"

    if ! echo "${PATH}" | tr ':' '\n' | grep -qxF "${link_dir}"; then
        echo ""
        echo "  ${link_dir} is not in your PATH. Add it with:"
        echo "    export PATH=\"${link_dir}:\$PATH\""
    fi
}

cmd_mock_build() {
    local mock_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            *) mock_args+=("$1"); shift ;;
        esac
    done

    # 1. Download toolchain sources
    if [[ ! -d "${SCRIPT_DIR}/sources" ]] || [[ -z "$(ls -A "${SCRIPT_DIR}/sources" 2>/dev/null)" ]]; then
        msg "Downloading toolchain sources..."
        bash "${SCRIPT_DIR}/scripts/download-sources.sh"
    else
        msg "Toolchain sources already downloaded"
    fi

    # 2. Create scripts tarball + link sources
    msg "Preparing RPM sources..."
    bash "${SCRIPT_DIR}/scripts/make-srpm-sources.sh"
    local sourcedir="${SCRIPT_DIR}/rpmbuild-sources"

    # 3. Build SRPM
    msg "Building SRPM..."
    local srpmdir
    srpmdir=$(mktemp -d)
    rpmbuild -bs "${SCRIPT_DIR}/msys2-cross.spec" \
        --define "_sourcedir ${sourcedir}" \
        --define "_srcrpmdir ${srpmdir}"

    local srpm
    srpm=$(ls "${srpmdir}"/*.src.rpm 2>/dev/null | head -1)
    if [[ -z "$srpm" ]]; then
        err "SRPM build failed"
        rm -rf "$srpmdir"
        exit 1
    fi
    msg "SRPM: ${srpm}"

    # 4. Rebuild in mock
    msg "Running mock --rebuild (this takes 30-60 minutes)..."
    mock --rebuild "$srpm" "${mock_args[@]}"
    local rc=$?

    rm -rf "$srpmdir"

    if [[ $rc -eq 0 ]]; then
        msg "Mock build succeeded!"
        msg "RPMs available in /var/lib/mock/*/result/"
    else
        err "Mock build failed (exit code ${rc})"
    fi
    return $rc
}

cmd_describe() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross describe <pkg>"
        exit 1
    fi

    ensure_mingw_packages

    local pkg
    pkg=$(normalize_pkg "$1")
    checkout_pkg "$pkg"
    local srcdir="${_checkout_actual}"
    local pkgbuild="${MINGW_PACKAGES_DIR}/${srcdir}/PKGBUILD"

    if [[ ! -f "$pkgbuild" ]]; then
        err "PKGBUILD not found for ${pkg}"
        exit 1
    fi

    local parsed
    parsed=$(parse_pkgbuild "$pkgbuild")
    if [[ -z "$parsed" ]]; then
        err "Failed to parse PKGBUILD for ${pkg}"
        exit 1
    fi
    eval "$parsed"

    echo -e "${BOLD}${_pkgbase}${NC} ${_pkgver}-${_pkgrel}"
    echo -e "  ${_pkgdesc}"
    echo ""
    [[ -n "${_url:-}" ]] && echo -e "  ${BOLD}URL:${NC}       ${_url}"

    if [[ ${#_license[@]} -gt 0 && -n "${_license[0]:-}" ]]; then
        echo -e "  ${BOLD}License:${NC}   ${_license[*]}"
    fi

    if [[ ${#_pkgname[@]} -gt 1 ]]; then
        echo -e "  ${BOLD}Packages:${NC}  ${_pkgname[*]}"
    fi

    # Dependencies (filter MINGW prefix for readability)
    local -a deps=() makedeps=()
    for d in "${_depends[@]}"; do
        [[ -z "$d" ]] && continue
        deps+=("${d/#\$\{MINGW_PACKAGE_PREFIX\}-/}")
        deps[-1]="${deps[-1]/#${MINGW_PACKAGE_PREFIX}-/}"
    done
    for d in "${_makedepends[@]}"; do
        [[ -z "$d" ]] && continue
        makedeps+=("${d/#\$\{MINGW_PACKAGE_PREFIX\}-/}")
        makedeps[-1]="${makedeps[-1]/#${MINGW_PACKAGE_PREFIX}-/}"
    done

    if [[ ${#deps[@]} -gt 0 ]]; then
        echo -e "  ${BOLD}Depends:${NC}   ${deps[*]}"
    fi
    if [[ ${#makedeps[@]} -gt 0 ]]; then
        echo -e "  ${BOLD}Makedeps:${NC}  ${makedeps[*]}"
    fi

    # Status info
    echo ""
    local -a status=()
    if [[ -f "${SCRIPT_DIR}/patches/${srcdir}.sh" ]]; then
        status+=("cross-patch available")
    fi
    if ls "${MINGW_PACKAGES_DIR}/${srcdir}"/*.pkg.tar.* &>/dev/null; then
        status+=("built")
    fi
    if prun pacman --config "${PACMAN_CONF}" -Qq "${_pkgname[0]/#\$\{MINGW_PACKAGE_PREFIX\}/${MINGW_PACKAGE_PREFIX}}" &>/dev/null 2>&1; then
        status+=("installed")
    fi
    if [[ ${#status[@]} -gt 0 ]]; then
        echo -e "  ${BOLD}Status:${NC}    ${status[*]}"
    fi
}

UPSTREAM_CONF_TEMPLATE="/opt/msys2-cross/config/pacman-mingw-upstream.conf.in"
UPSTREAM_PACMAN_CONF="/tmp/pacman-mingw-upstream.conf"

_UPSTREAM_INIT="sed -e 's|@CMAKE_SYSTEM_PROCESSOR@|${CMAKE_SYSTEM_PROCESSOR}|g' \
    -e 's|@MSYSTEM_LOWER@|${MSYSTEM_LOWER}|g' \
    ${UPSTREAM_CONF_TEMPLATE} > ${UPSTREAM_PACMAN_CONF}"

cmd_upstream() {
    if [[ $# -eq 0 ]]; then
        err "Usage: msys2-cross upstream <install|install-dep|search> <pkg|pattern>"
        exit 1
    fi

    local subcmd="$1"
    shift

    ensure_image

    case "$subcmd" in
        install)
            if [[ $# -eq 0 ]]; then
                err "Usage: msys2-cross upstream install <pkg> [...]"
                exit 1
            fi

            local -a pkgs=()
            for raw_pkg in "$@"; do
                if [[ "$raw_pkg" == ${MINGW_PACKAGE_PREFIX}-* ]]; then
                    pkgs+=("$raw_pkg")
                else
                    pkgs+=("${MINGW_PACKAGE_PREFIX}-${raw_pkg}")
                fi
            done

            msg "Installing from upstream MSYS2 [${MSYSTEM}]: ${pkgs[*]}"

            local container="msys2-cross-upstream-$$"
            local image
            image="$(current_image)"

            podman run --init \
                --name "${container}" \
                --network=pasta \
                --user root \
                "${VOLUMES[@]}" \
                "${image}" bash -c \
                "${_UPSTREAM_INIT} && \
                 pacman --config ${UPSTREAM_PACMAN_CONF} -Sy --noconfirm && \
                 pacman --config ${UPSTREAM_PACMAN_CONF} -S --noconfirm --needed ${pkgs[*]}" 2>&1
            local rc=$?

            if [[ $rc -eq 0 ]]; then
                podman commit -q --change 'USER builduser' "${container}" "${WORK_IMAGE}" >/dev/null
                msg "Installed and committed to working image"
            else
                err "Upstream install failed"
            fi
            podman rm -f "${container}" >/dev/null 2>&1
            return $rc
            ;;
        install-dep)
            if [[ $# -eq 0 ]]; then
                err "Usage: msys2-cross upstream install-dep <pkg> [...]"
                exit 1
            fi

            ensure_mingw_packages

            local -A dummies=()
            load_dummy_packages dummies

            local -a all_deps=()
            for raw_pkg in "$@"; do
                local pkg
                pkg=$(normalize_pkg "$raw_pkg")
                checkout_pkg "$pkg"
                local srcdir="${_checkout_actual}"
                local pkgbuild="${MINGW_PACKAGES_DIR}/${srcdir}/PKGBUILD"

                if [[ ! -f "$pkgbuild" ]]; then
                    err "PKGBUILD not found for ${pkg}"
                    exit 1
                fi

                local parsed
                parsed=$(parse_pkgbuild "$pkgbuild")
                eval "$parsed"

                for dep in "${_depends[@]}" "${_makedepends[@]}"; do
                    [[ -z "$dep" ]] && continue
                    dep="${dep%%[><=]*}"
                    [[ "$dep" == ${MINGW_PACKAGE_PREFIX}-* ]] || continue
                    [[ -n "${dummies[$dep]+x}" ]] && continue
                    all_deps+=("$dep")
                done
            done

            if [[ ${#all_deps[@]} -eq 0 ]]; then
                msg "No upstream dependencies to install"
                return 0
            fi

            local -a unique_deps=()
            local -A seen=()
            for dep in "${all_deps[@]}"; do
                if [[ -z "${seen[$dep]+x}" ]]; then
                    seen[$dep]=1
                    unique_deps+=("$dep")
                fi
            done

            msg "Installing build deps from upstream MSYS2 [${MSYSTEM}]:"
            for dep in "${unique_deps[@]}"; do echo "  ${dep}"; done

            local container="msys2-cross-upstream-$$"
            local image
            image="$(current_image)"

            podman run --init \
                --name "${container}" \
                --network=pasta \
                --user root \
                "${VOLUMES[@]}" \
                "${image}" bash -c \
                "${_UPSTREAM_INIT} && \
                 pacman --config ${UPSTREAM_PACMAN_CONF} -Sy --noconfirm && \
                 pacman --config ${UPSTREAM_PACMAN_CONF} -S --noconfirm --needed ${unique_deps[*]}" 2>&1
            local rc=$?

            if [[ $rc -eq 0 ]]; then
                podman commit -q --change 'USER builduser' "${container}" "${WORK_IMAGE}" >/dev/null
                msg "Installed and committed to working image"
            else
                err "Upstream install-dep failed"
            fi
            podman rm -f "${container}" >/dev/null 2>&1
            return $rc
            ;;
        search)
            if [[ $# -eq 0 ]]; then
                err "Usage: msys2-cross upstream search <pattern>"
                exit 1
            fi

            podman run --rm --init \
                --network=pasta \
                --user root \
                "${VOLUMES[@]}" \
                "$(current_image)" bash -c \
                "${_UPSTREAM_INIT} && \
                 pacman --config ${UPSTREAM_PACMAN_CONF} -Sy >/dev/null && \
                 pacman --config ${UPSTREAM_PACMAN_CONF} -Ss $*"
            ;;
        *)
            err "Unknown upstream subcommand: ${subcmd}"
            err "Usage: msys2-cross upstream <install|install-dep|search> <pkg|pattern>"
            exit 1
            ;;
    esac
}

cmd_check_update() {
    local github_raw="https://raw.githubusercontent.com/msys2/MINGW-packages/master"
    local rc=0

    _extract_pkgver() {
        local text="$1"
        local ver
        ver=$(echo "$text" | grep -m1 '^_pkgver=' | cut -d= -f2 | tr -d "'\"")
        if [[ -z "$ver" ]]; then
            ver=$(echo "$text" | grep -m1 '^pkgver=' | cut -d= -f2 | tr -d "'\"")
            if [[ "$ver" =~ ^\$\{?([a-zA-Z_][a-zA-Z0-9_]*)\}?$ ]]; then
                local varname="${BASH_REMATCH[1]}"
                ver=$(echo "$text" | grep -m1 "^${varname}=" | cut -d= -f2 | tr -d "'\"")
            fi
        fi
        echo "$ver"
    }

    _compare() {
        local label="$1" local_ver="$2" upstream_ver="$3"
        if [[ -z "$upstream_ver" ]]; then
            printf "  ${YELLOW}??${NC}  %-14s %s ${YELLOW}(upstream unknown)${NC}\n" "$label" "$local_ver"
        elif [[ "$local_ver" == "$upstream_ver" ]]; then
            printf "  ${GREEN}OK${NC}  %-14s %s\n" "$label" "$local_ver"
        else
            printf "  ${YELLOW}!!${NC}  %-14s %s → %s\n" "$label" "$local_ver" "$upstream_ver"
            rc=1
        fi
    }

    msg "Checking upstream MSYS2 package versions..."

    local local_gcc local_binutils local_llvm local_mingw_commit local_rust
    local_gcc=$(grep '^GCC_VERSION=' "${SCRIPT_DIR}/scripts/common.sh" | cut -d= -f2)
    local_binutils=$(grep '^BINUTILS_VERSION=' "${SCRIPT_DIR}/scripts/common.sh" | cut -d= -f2)
    local_llvm=$(grep '^LLVM_VERSION=' "${SCRIPT_DIR}/scripts/common.sh" | cut -d= -f2)
    local_mingw_commit=$(grep '^MINGW_W64_COMMIT=' "${SCRIPT_DIR}/scripts/common.sh" | cut -d= -f2)
    local_rust=$(grep '^RUST_VERSION=' "${SCRIPT_DIR}/scripts/common.sh" | cut -d= -f2)

    local upstream_pkgbuild

    echo ""
    echo "Toolchain (pinned in scripts/common.sh):"

    for pair in "gcc:mingw-w64-gcc:$local_gcc" "binutils:mingw-w64-binutils:$local_binutils" \
                "llvm:mingw-w64-llvm:$local_llvm" "rust:mingw-w64-rust:$local_rust"; do
        local name="${pair%%:*}" rest="${pair#*:}"
        local pkg="${rest%%:*}" local_ver="${rest#*:}"
        upstream_pkgbuild=$(curl -fsSL "${github_raw}/${pkg}/PKGBUILD" 2>/dev/null) || true
        _compare "$name" "$local_ver" "$(_extract_pkgver "$upstream_pkgbuild")"
    done

    local upstream_commit
    upstream_pkgbuild=$(curl -fsSL "${github_raw}/mingw-w64-crt/PKGBUILD" 2>/dev/null) || true
    upstream_commit=$(echo "$upstream_pkgbuild" | grep -m1 '^_commit=' | cut -d= -f2 | tr -d "'\"")
    _compare "mingw-w64" "${local_mingw_commit:0:12}" "${upstream_commit:0:12}"

    local core_libs=(bzip2 zlib xz zstd libiconv gettext libffi pcre2 expat)
    echo ""
    echo "Core libraries (built in bootstrap):"

    for lib in "${core_libs[@]}"; do
        local pkg="mingw-w64-${lib}"
        local local_ver=""
        if [[ -f "${MINGW_PACKAGES_DIR}/${pkg}/PKGBUILD" ]]; then
            local_ver=$(_extract_pkgver "$(cat "${MINGW_PACKAGES_DIR}/${pkg}/PKGBUILD")")
        fi

        upstream_pkgbuild=$(curl -fsSL "${github_raw}/${pkg}/PKGBUILD" 2>/dev/null) || true
        local upstream_ver
        upstream_ver=$(_extract_pkgver "$upstream_pkgbuild")

        if [[ -z "$local_ver" ]]; then
            printf "  ${YELLOW}--${NC}  %-14s (not checked out, upstream=%s)\n" "$lib" "${upstream_ver:-?}"
        else
            _compare "$lib" "$local_ver" "$upstream_ver"
        fi
    done

    echo ""
    if [[ "$rc" -ne 0 ]]; then
        warn "Version differences found — see above."
        echo "  To update toolchain: edit scripts/common.sh, then ./msys2-cross rebuild"
        echo "  To update core libs: cd MINGW-packages && git pull"
    else
        msg "All bootstrap versions match upstream MSYS2."
    fi
    return $rc
}

# --- Main ---
if [[ $# -eq 0 ]]; then
    usage
fi

case "$1" in
    setup)    shift; cmd_setup "$@" ;;
    download) shift; cmd_download "$@" ;;
    build)    shift; cmd_build "$@" ;;
    install)  shift; cmd_install "$@" ;;
    deps)     shift; cmd_deps "$@" ;;
    describe) shift; cmd_describe "$@" ;;
    shell)    shift; cmd_shell "$@" ;;
    run)      shift; cmd_run "$@" ;;
    list)     shift; cmd_list "$@" ;;
    diff)     shift; cmd_diff "$@" ;;
    reset)    shift; cmd_reset "$@" ;;
    destroy)  shift; cmd_destroy "$@" ;;
    rebuild)      shift; cmd_rebuild "$@" ;;
    upstream)     shift; cmd_upstream "$@" ;;
    check-update) shift; cmd_check_update "$@" ;;
    srpm)       shift; bash "${SCRIPT_DIR}/scripts/make-mingw-srpm.sh" "$@" ;;
    mock-build) shift; cmd_mock_build "$@" ;;
    link)       shift; cmd_link "$@" ;;
    complete)
        shift
        case "${1:-}" in
            zsh)
                cat <<EVAL
fpath=(${SCRIPT_DIR}/completions/zsh \$fpath)
autoload -Uz _msys2-cross
(( \$+functions[compdef] )) && compdef _msys2-cross msys2-cross
EVAL
                ;;
            *)
                err "Usage: eval \"\$(msys2-cross complete zsh)\""
                exit 1
                ;;
        esac
        ;;
    help|-h|--help) usage 0 ;;
    *)        err "Unknown command: $1"; usage 1 ;;
esac
