# Dummy pacman packages for the mingw DB.
# Package names are base names — the environment-specific prefix
# (e.g., mingw-w64-ucrt-x86_64-) is prepended by 08-setup-pacman.sh.
#
# Sections:
#   [host]   — unprefixed MSYS2-layer host tools (always included)
#   [shared] — MINGW deps that apply to all environments
#   [gcc]    — GCC-specific dummy packages
#   [clang]  — Clang/LLVM-specific dummy packages

# [host]
autoconf-archive
docbook-xsl
git
groff
po4a
xmlto

