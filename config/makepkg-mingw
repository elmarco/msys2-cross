#!/bin/bash
#
# makepkg-mingw — Linux-adapted version of MSYS2's makepkg-mingw.
# Drives makepkg for cross-compilation of MINGW packages on Linux.
#
# On MSYS2, this script spawns a login shell per architecture to get
# MSYSTEM-specific env vars. On Linux we export them directly since
# we only target UCRT64.

set -euo pipefail

BOOTSTRAP_DIR=/opt/msys2-cross
PATCHES_DIR="${BOOTSTRAP_DIR}/patches"
BUILD_TRIPLE=$(gcc -dumpmachine)

msg() { echo -e "\033[1;32m==>\033[0m \033[1m$1\033[0m"; }
error() { echo -e "\033[1;31m==> ERROR:\033[0m \033[1m$1\033[0m" >&2; }

# Source the cross-compilation environment
source "${BOOTSTRAP_DIR}/config/mingw-env.sh"

msg "Building for UCRT64 (${MINGW_CHOST})"

# Determine makepkg config
MAKEPKG_CONF="${BOOTSTRAP_DIR}/config/makepkg_mingw.conf"

if [[ ! -f "${MAKEPKG_CONF}" ]]; then
    error "makepkg config not found: ${MAKEPKG_CONF}"
    exit 1
fi

if [[ ! -f PKGBUILD ]]; then
    error "No PKGBUILD in current directory"
    exit 1
fi

# --- Modify PKGBUILD for cross-compilation ---
# Back up the original so we can restore it after build
cp PKGBUILD PKGBUILD.orig

# 1. Apply per-package patch FIRST (patches match upstream PKGBUILD)
_pkgbase=$(basename "$(pwd)")
_patch="${PATCHES_DIR}/${_pkgbase}.sh"
if [[ -f "${_patch}" ]]; then
    msg "Applying cross-compilation patch: ${_pkgbase}.sh"
    source "${_patch}"
fi

# 2. Auto-rewrite common MSYS2 patterns for cross-compilation

# Add --host and --build to autotools configure calls.
# Only match lines containing "configure" (not meson/cmake).
sed -i \
    -e "/configure/s|--prefix=\${MINGW_PREFIX}|--host=\${MINGW_CHOST} --build=${BUILD_TRIPLE} --prefix=\${MINGW_PREFIX}|g" \
    PKGBUILD

# Fix --build=${MINGW_CHOST} → --build=<linux-triple> (for explicit --build)
sed -i \
    -e "s|--build=\${MINGW_CHOST}|--build=${BUILD_TRIPLE}|g" \
    -e "s|--build=\"\${MINGW_CHOST}\"|--build=${BUILD_TRIPLE}|g" \
    -e "s|--build=\${CHOST}|--build=${BUILD_TRIPLE}|g" \
    PKGBUILD

# Fix CHOST=${MINGW_CHOST} ./configure pattern (zlib-style)
# Handle both single-line and multi-line (backslash continuation) forms:
#   CHOST=${MINGW_CHOST} ./configure ...
#   CHOST=${MINGW_CHOST} \
#   ../zlib-1.3.1/configure ...
sed -i \
    -e 's|CHOST=\${MINGW_CHOST} \(\.\./[^ ]*/configure\)|CC=${MINGW_CHOST}-gcc \1 --host=${MINGW_CHOST} --build='"${BUILD_TRIPLE}"'|g' \
    -e 's|CHOST=\${MINGW_CHOST} \(\./configure\)|CC=${MINGW_CHOST}-gcc \1 --host=${MINGW_CHOST} --build='"${BUILD_TRIPLE}"'|g' \
    PKGBUILD
# Multi-line: CHOST=${MINGW_CHOST} \ (next line has configure)
sed -i -e '/CHOST=\${MINGW_CHOST} *\\$/{
    s|CHOST=\${MINGW_CHOST}|CC=${MINGW_CHOST}-gcc|
    n
    s|\([ ]*\)\(\.\{0,2\}/[^ ]*/configure\)|\1\2 --host=${MINGW_CHOST} --build='"${BUILD_TRIPLE}"'|
}' PKGBUILD

# Replace meson.exe / meson with our wrappers (setup vs compile/install)
# Handle both ${MINGW_PREFIX}/bin/ and "${MINGW_PREFIX}"/bin/ quoting styles
sed -i \
    -e 's|${MINGW_PREFIX}/bin/meson\(\.exe\)\{0,1\} setup|/opt/msys2-cross/wrappers/mingw-meson|g' \
    -e 's|"${MINGW_PREFIX}"/bin/meson\(\.exe\)\{0,1\} setup|/opt/msys2-cross/wrappers/mingw-meson|g' \
    -e 's|${MINGW_PREFIX}/bin/meson\(\.exe\)\{0,1\} compile|/usr/bin/meson compile|g' \
    -e 's|"${MINGW_PREFIX}"/bin/meson\(\.exe\)\{0,1\} compile|/usr/bin/meson compile|g' \
    -e 's|${MINGW_PREFIX}/bin/meson\(\.exe\)\{0,1\} install|/usr/bin/meson install|g' \
    -e 's|"${MINGW_PREFIX}"/bin/meson\(\.exe\)\{0,1\} install|/usr/bin/meson install|g' \
    -e 's|${MINGW_PREFIX}/bin/meson\(\.exe\)\{0,1\}\b|/usr/bin/meson|g' \
    -e 's|"${MINGW_PREFIX}"/bin/meson\(\.exe\)\{0,1\}\b|/usr/bin/meson|g' \
    PKGBUILD

# Handle bare meson calls (newer PKGBUILDs without ${MINGW_PREFIX}/bin/ prefix)
sed -i \
    -e '/\/meson/!s|^\(\s*\)meson setup\b|\1/opt/msys2-cross/wrappers/mingw-meson|' \
    -e '/\/meson/!s|^\(\s*\)meson compile\b|\1/usr/bin/meson compile|' \
    -e '/\/meson/!s|^\(\s*\)meson install\b|\1/usr/bin/meson install|' \
    PKGBUILD

# Replace cmake.exe with our wrapper (handles both quoting styles)
sed -i \
    -e 's|${MINGW_PREFIX}/bin/cmake\.exe|/ucrt64/bin/cmake|g' \
    -e 's|"${MINGW_PREFIX}"/bin/cmake\.exe|/ucrt64/bin/cmake|g' \
    -e 's|${MINGW_PREFIX}/bin/cmake\b|/ucrt64/bin/cmake|g' \
    -e 's|"${MINGW_PREFIX}"/bin/cmake\b|/ucrt64/bin/cmake|g' \
    PKGBUILD

# Remove MSYS2_ARG_CONV_EXCL (MSYS2-only path conversion suppression).
# It's typically used as an env var prefix with line continuation:
#   MSYS2_ARG_CONV_EXCL="--prefix=" \
# Replace with nothing but preserve the command on the next line.
sed -i 's/MSYS2_ARG_CONV_EXCL="[^"]*" \\$//' PKGBUILD
sed -i 's/MSYS2_ARG_CONV_EXCL="[^"]*" //' PKGBUILD

# Rewrite MINGW python exe references to host python
sed -i \
    -e 's|${MINGW_PREFIX}/bin/python3\(\.exe\)\{0,1\}|/usr/bin/python3|g' \
    -e 's|${MINGW_PREFIX}/bin/python\(\.exe\)\{0,1\}|/usr/bin/python3|g' \
    -e 's|-DPython3_EXECUTABLE=[^ ]*|-DPython3_EXECUTABLE=/usr/bin/python3|g' \
    -e 's|-DPython_EXECUTABLE=[^ ]*|-DPython_EXECUTABLE=/usr/bin/python3|g' \
    -e 's|-DPYTHON_EXECUTABLE=[^ ]*|-DPYTHON_EXECUTABLE=/usr/bin/python3|g' \
    PKGBUILD

# Remove noextract + manual tar (MSYS2 path workaround, not needed on Linux).
# Replace tar lines with 'true' instead of deleting (preserves function body).
sed -i '/^noextract=/d' PKGBUILD
sed -i 's|^[[:space:]]*tar -xf.*\.tar.*|  true  # noextract tar removed|' PKGBUILD

# --- Validate rewrites ---
# Warn when a PKGBUILD looks like it should have been rewritten but wasn't.
# These are heuristic: a warning doesn't mean the build will fail, but it
# flags cases where a sed pattern silently missed.
_rewrite_warnings=0
_warn_rewrite() { echo -e "\033[1;33m  -> WARNING:\033[0m $1"; _rewrite_warnings=$((_rewrite_warnings + 1)); }

if grep -qP '^\s*(\.\./[^ ]*/)?\.?/configure\b' PKGBUILD; then
    if ! grep -q -- '--host=' PKGBUILD; then
        _warn_rewrite "PKGBUILD has ./configure but no --host= flag after rewrite"
    fi
    if grep -qP -- '--build=\$\{?MINGW_CHOST\}?' PKGBUILD; then
        _warn_rewrite "PKGBUILD still has --build=\${MINGW_CHOST} after rewrite"
    fi
fi

if grep -qP 'CHOST=\$\{?MINGW_CHOST\}?' PKGBUILD; then
    _warn_rewrite "PKGBUILD still has CHOST=\${MINGW_CHOST} after rewrite"
fi

if grep -q 'MSYS2_ARG_CONV_EXCL' PKGBUILD; then
    _warn_rewrite "PKGBUILD still has MSYS2_ARG_CONV_EXCL after rewrite"
fi

if grep -qP '\$\{MINGW_PREFIX\}["/]*bin/meson\b' PKGBUILD; then
    _warn_rewrite "PKGBUILD still references \${MINGW_PREFIX}/bin/meson after rewrite"
fi

if grep -qP '\$\{MINGW_PREFIX\}["/]*bin/cmake\b' PKGBUILD; then
    _warn_rewrite "PKGBUILD still references \${MINGW_PREFIX}/bin/cmake after rewrite"
fi

if [[ $_rewrite_warnings -gt 0 ]]; then
    echo -e "\033[1;33m==> WARNING:\033[0m ${_rewrite_warnings} rewrite warning(s) — build may fail or produce native binaries"
fi

# --- Build ---
# --nodeps: skip MSYS-layer dependency checks (autoconf, python, etc.)
#           which don't exist in our pacman DB.
if [[ "$(id -u)" == "0" ]]; then
    # makepkg refuses to run as root — drop to builduser
    useradd -m builduser 2>/dev/null || true
    chown -R builduser: "$(pwd)" /home/builduser 2>/dev/null || true
    su builduser -s /bin/bash -c "makepkg --config '${MAKEPKG_CONF}' --nodeps --skippgpcheck $*"
    _rc=$?
else
    makepkg --config "${MAKEPKG_CONF}" --nodeps --skippgpcheck "$@"
    _rc=$?
fi

# Restore original PKGBUILD
mv PKGBUILD.orig PKGBUILD

exit ${_rc}
