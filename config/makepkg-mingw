#!/bin/bash
#
# makepkg-mingw — Linux-adapted version of MSYS2's makepkg-mingw.
# Drives makepkg for cross-compilation of MINGW packages on Linux.
#
# On MSYS2, this script spawns a login shell per architecture to get
# MSYSTEM-specific env vars. On Linux we export them directly since
# we only target UCRT64.

set -euo pipefail

BOOTSTRAP_DIR=/opt/msys2-cross
PATCHES_DIR="${BOOTSTRAP_DIR}/patches"
BUILD_TRIPLE=$(gcc -dumpmachine)

msg() { echo -e "\033[1;32m==>\033[0m \033[1m$1\033[0m"; }
error() { echo -e "\033[1;31m==> ERROR:\033[0m \033[1m$1\033[0m" >&2; }

# Source the cross-compilation environment
source "${BOOTSTRAP_DIR}/config/mingw-env.sh"

msg "Building for UCRT64 (${MINGW_CHOST})"

# Determine makepkg config
MAKEPKG_CONF="${BOOTSTRAP_DIR}/config/makepkg_mingw.conf"

if [[ ! -f "${MAKEPKG_CONF}" ]]; then
    error "makepkg config not found: ${MAKEPKG_CONF}"
    exit 1
fi

if [[ ! -f PKGBUILD ]]; then
    error "No PKGBUILD in current directory"
    exit 1
fi

# --- Modify PKGBUILD for cross-compilation ---
# Back up the original so we can restore it after build
cp PKGBUILD PKGBUILD.orig

# 1. Apply per-package patch FIRST (patches match upstream PKGBUILD)
_pkgbase=$(basename "$(pwd)")
_patch="${PATCHES_DIR}/${_pkgbase}.sh"
if [[ -f "${_patch}" ]]; then
    msg "Applying cross-compilation patch: ${_pkgbase}.sh"
    source "${_patch}"
fi

# 2. Auto-rewrite common MSYS2 patterns for cross-compilation

# Add --host and --build to every configure call that has --prefix=${MINGW_PREFIX}.
# If the PKGBUILD already has --host/--build, the duplicates are harmless
# (autotools uses the last value, or it's the same value).
sed -i \
    -e "s|--prefix=\${MINGW_PREFIX}|--host=\${MINGW_CHOST} --build=${BUILD_TRIPLE} --prefix=\${MINGW_PREFIX}|g" \
    PKGBUILD

# Fix --build=${MINGW_CHOST} → --build=<linux-triple> (for explicit --build)
sed -i \
    -e "s|--build=\${MINGW_CHOST}|--build=${BUILD_TRIPLE}|g" \
    -e "s|--build=\${CHOST}|--build=${BUILD_TRIPLE}|g" \
    PKGBUILD

# Fix CHOST=${MINGW_CHOST} ./configure pattern (zlib-style)
sed -i \
    -e 's|CHOST=\${MINGW_CHOST} \(\.\./[^ ]*/configure\)|CC=${MINGW_CHOST}-gcc \1 --host=${MINGW_CHOST} --build='"${BUILD_TRIPLE}"'|g' \
    -e 's|CHOST=\${MINGW_CHOST} \(\./configure\)|CC=${MINGW_CHOST}-gcc \1 --host=${MINGW_CHOST} --build='"${BUILD_TRIPLE}"'|g' \
    PKGBUILD

# Replace meson.exe with our wrappers (setup vs compile/install)
sed -i \
    -e 's|${MINGW_PREFIX}/bin/meson\.exe setup|/opt/msys2-cross/wrappers/mingw-meson|g' \
    -e 's|${MINGW_PREFIX}/bin/meson\.exe compile|/usr/bin/meson compile|g' \
    -e 's|${MINGW_PREFIX}/bin/meson\.exe install|/usr/bin/meson install|g' \
    -e 's|${MINGW_PREFIX}/bin/meson\.exe|/usr/bin/meson|g' \
    PKGBUILD

# Remove MSYS2_ARG_CONV_EXCL (MSYS2-only path conversion suppression)
sed -i '/MSYS2_ARG_CONV_EXCL/d' PKGBUILD

# Remove noextract + manual tar (MSYS2 path workaround, not needed on Linux)
sed -i '/^noextract=/d' PKGBUILD
sed -i '/^[[:space:]]*tar -xf.*\.tar/d' PKGBUILD

# --- Build ---
# --nodeps: skip MSYS-layer dependency checks (autoconf, python, etc.)
#           which don't exist in our pacman DB.
if [[ "$(id -u)" == "0" ]]; then
    # makepkg refuses to run as root — drop to builduser
    useradd -m builduser 2>/dev/null || true
    chown -R builduser: "$(pwd)"
    su builduser -s /bin/bash -c "makepkg --config '${MAKEPKG_CONF}' --nodeps $*"
    _rc=$?
else
    makepkg --config "${MAKEPKG_CONF}" --nodeps "$@"
    _rc=$?
fi

# Restore original PKGBUILD
mv PKGBUILD.orig PKGBUILD

exit ${_rc}
