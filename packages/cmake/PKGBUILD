pkgname=${MINGW_PACKAGE_PREFIX}-cmake
pkgver=1.0
pkgrel=1
pkgdesc="CMake wrapper for cross-compilation on Linux"
arch=('any')
url="https://cmake.org/"
license=('MIT')

package() {
    install -Dm755 /opt/msys2-cross/wrappers/mingw-cmake \
        "${pkgdir}/opt/msys2-cross/wrappers/mingw-cmake"
    install -Dm644 /opt/msys2-cross/generated/toolchain.cmake \
        "${pkgdir}/opt/msys2-cross/generated/toolchain.cmake"
}
