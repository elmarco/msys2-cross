pkgname=mingw-w64-ucrt-x86_64-gobject-introspection
pkgver=1.82.0
pkgrel=1
pkgdesc="Dummy gobject-introspection — provides pkg-config for cross-compilation"
arch=('any')
license=('MIT')

package() {
    # Many packages require gobject-introspection-1.0.pc at configure time
    # even when introspection is disabled.
    mkdir -p "${pkgdir}/ucrt64/lib/pkgconfig"
    cat > "${pkgdir}/ucrt64/lib/pkgconfig/gobject-introspection-1.0.pc" << EOF
prefix=/ucrt64
Name: gobject-introspection
Description: dummy for cross-compilation
Version: ${pkgver}
Cflags:
Libs:
EOF
}
