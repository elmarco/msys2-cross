pkgname=mingw-w64-ucrt-x86_64-cross-winpthreads
pkgver=14.0.0
pkgrel=1
pkgdesc="MinGW-w64 winpthreads for UCRT64 (bootstrap)"
arch=('any')
url="https://www.mingw-w64.org/"
license=('MIT' 'custom')
depends=('mingw-w64-ucrt-x86_64-cross-crt')
provides=(
    'mingw-w64-ucrt-x86_64-winpthreads-git'
    'mingw-w64-ucrt-x86_64-libwinpthread-git'
)
conflicts=(
    'mingw-w64-ucrt-x86_64-winpthreads-git'
    'mingw-w64-ucrt-x86_64-libwinpthread-git'
)

package() {
    mkdir -p "${pkgdir}/ucrt64/"{bin,lib,include}

    # Headers
    cp -a /ucrt64/include/pthread*.h "${pkgdir}/ucrt64/include/" 2>/dev/null || true
    cp -a /ucrt64/include/sched.h "${pkgdir}/ucrt64/include/" 2>/dev/null || true
    cp -a /ucrt64/include/semaphore.h "${pkgdir}/ucrt64/include/" 2>/dev/null || true

    # Libraries
    cp -a /ucrt64/lib/libpthread*.a "${pkgdir}/ucrt64/lib/" 2>/dev/null || true
    cp -a /ucrt64/lib/libwinpthread*.a "${pkgdir}/ucrt64/lib/" 2>/dev/null || true

    # DLL
    cp -a /ucrt64/bin/libwinpthread*.dll "${pkgdir}/ucrt64/bin/" 2>/dev/null || true
}
